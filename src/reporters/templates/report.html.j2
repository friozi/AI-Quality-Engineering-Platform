<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LLM QA Report — {{ metrics.model_key | default("unknown") }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f0f4f8;
      color: #1e293b;
      font-size: 14px;
      line-height: 1.5;
    }

    .container { max-width: 1440px; margin: 0 auto; padding: 24px; }

    /* ── Header ─────────────────────────────────────────────────────── */
    header {
      background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
      color: #fff;
      padding: 28px 32px;
      border-radius: 12px;
      margin-bottom: 24px;
    }
    header h1 { font-size: 1.6rem; font-weight: 700; letter-spacing: -0.5px; }
    header h1 span { color: #60a5fa; }
    .meta {
      display: flex; flex-wrap: wrap; gap: 20px;
      margin-top: 12px; font-size: 0.82rem; color: #94a3b8;
    }
    .meta strong { color: #e2e8f0; }

    /* ── Summary cards ───────────────────────────────────────────────── */
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }
    .card {
      background: #fff;
      border-radius: 10px;
      padding: 20px 16px;
      text-align: center;
      box-shadow: 0 1px 4px rgba(0,0,0,.08);
      border-top: 3px solid #e2e8f0;
    }
    .card-value { font-size: 2rem; font-weight: 800; line-height: 1.1; }
    .card-label { font-size: 0.78rem; color: #64748b; margin-top: 6px; text-transform: uppercase; letter-spacing: .5px; }
    .card.green  { border-color: #22c55e; } .card.green  .card-value { color: #16a34a; }
    .card.red    { border-color: #ef4444; } .card.red    .card-value { color: #dc2626; }
    .card.blue   { border-color: #3b82f6; } .card.blue   .card-value { color: #2563eb; }
    .card.purple { border-color: #a855f7; } .card.purple .card-value { color: #9333ea; }
    .card.amber  { border-color: #f59e0b; } .card.amber  .card-value { color: #d97706; }

    /* ── Sections ────────────────────────────────────────────────────── */
    section {
      background: #fff;
      border-radius: 10px;
      padding: 24px;
      margin-bottom: 24px;
      box-shadow: 0 1px 4px rgba(0,0,0,.08);
    }
    h2 {
      font-size: 1rem; font-weight: 700; color: #0f172a;
      padding-bottom: 10px; margin-bottom: 16px;
      border-bottom: 2px solid #e2e8f0;
    }

    /* ── Tables ──────────────────────────────────────────────────────── */
    table { width: 100%; border-collapse: collapse; }
    th {
      background: #f8fafc; text-align: left;
      padding: 9px 12px; font-size: 0.78rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .4px; color: #475569;
      border-bottom: 2px solid #e2e8f0;
    }
    td { padding: 8px 12px; border-bottom: 1px solid #f1f5f9; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #f8fafc; }

    /* Result row colours */
    .row-pass td { background: #f0fdf4; }
    .row-fail td { background: #fef2f2; }
    .row-pass:hover td { background: #dcfce7; }
    .row-fail:hover td { background: #fee2e2; }

    /* Failure detail row */
    .row-detail td {
      background: #fffbeb !important;
      padding: 4px 12px 10px 28px;
      font-size: 0.8rem; color: #78350f;
      border-bottom: 1px solid #fde68a;
    }

    /* Inline badges */
    .pass  { color: #16a34a; font-weight: 700; }
    .fail  { color: #dc2626; font-weight: 700; }
    .warn  { color: #d97706; font-weight: 700; }
    .muted { color: #94a3b8; }

    .badge {
      display: inline-block; padding: 2px 8px; border-radius: 999px;
      font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    }
    .badge-ideal  { background: #dcfce7; color: #166534; }
    .badge-lucky  { background: #fef9c3; color: #854d0e; }
    .badge-error  { background: #ffedd5; color: #9a3412; }
    .badge-fail   { background: #fee2e2; color: #991b1b; }
    .badge-n_a    { background: #f1f5f9; color: #64748b; }
    .badge-pass   { background: #dcfce7; color: #166534; }
    .badge-nopass { background: #fee2e2; color: #991b1b; }

    /* Process quality grid */
    .pq-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 10px;
    }
    .pq-cell {
      text-align: center; padding: 14px 8px;
      border-radius: 8px; border: 1px solid #e2e8f0;
    }
    .pq-count { font-size: 1.8rem; font-weight: 800; }
    .pq-label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; margin-top: 2px; }
    .pq-ideal { background:#f0fdf4; border-color:#86efac; } .pq-ideal .pq-count { color:#16a34a; } .pq-ideal .pq-label { color:#15803d; }
    .pq-lucky { background:#fefce8; border-color:#fde047; } .pq-lucky .pq-count { color:#ca8a04; } .pq-lucky .pq-label { color:#a16207; }
    .pq-error { background:#fff7ed; border-color:#fdba74; } .pq-error .pq-count { color:#ea580c; } .pq-error .pq-label { color:#c2410c; }
    .pq-fail  { background:#fef2f2; border-color:#fca5a5; } .pq-fail  .pq-count { color:#dc2626; } .pq-fail  .pq-label { color:#b91c1c; }
    .pq-legend { font-size:0.78rem; color:#64748b; margin-top:8px; }
    .pq-legend span { margin-right:16px; }

    /* Latency stats row */
    .latency-grid {
      display: grid; grid-template-columns: repeat(5, 1fr); gap:12px;
    }
    .lat-cell { text-align:center; padding:12px; background:#f8fafc; border-radius:8px; }
    .lat-value { font-size:1.4rem; font-weight:800; color:#1e40af; }
    .lat-label { font-size:0.72rem; color:#64748b; text-transform:uppercase; letter-spacing:.4px; margin-top:2px; }

    /* Truncated text */
    .truncate { max-width:340px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; display:block; }

    footer {
      text-align:center; color:#94a3b8; font-size:0.78rem;
      padding:20px 0 8px;
    }
  </style>
</head>
<body>
<div class="container">

  <!-- ── Header ─────────────────────────────────────────────────── -->
  <header>
    <h1>LLM QA <span>Evaluation Report</span></h1>
    <div class="meta">
      <span>Model: <strong>{{ metrics.model_key | default("—") }}</strong></span>
      {% if metrics.model_name %}<span>Name: <strong>{{ metrics.model_name }}</strong></span>{% endif %}
      <span>Run ID: <strong>{{ metrics.run_id | truncate(16, true, '') }}</strong></span>
      <span>Generated: <strong>{{ generated_at }}</strong></span>
    </div>
  </header>

  <!-- ── Summary Cards ─────────────────────────────────────────── -->
  <div class="cards">
    <div class="card {% if metrics.overall_pass_rate >= 0.8 %}green{% else %}red{% endif %}">
      <div class="card-value">{{ (metrics.overall_pass_rate * 100) | round(1) }}%</div>
      <div class="card-label">Pass Rate</div>
    </div>
    <div class="card blue">
      <div class="card-value">{{ metrics.total_tests }}</div>
      <div class="card-label">Total Tests</div>
    </div>
    <div class="card green">
      <div class="card-value">{{ metrics.total_passed }}</div>
      <div class="card-label">Passed</div>
    </div>
    <div class="card red">
      <div class="card-value">{{ metrics.total_failed }}</div>
      <div class="card-label">Failed</div>
    </div>
    <div class="card {% if metrics.overall_quality_score >= 0.8 %}green{% elif metrics.overall_quality_score >= 0.6 %}amber{% else %}red{% endif %}">
      <div class="card-value">{{ (metrics.overall_quality_score * 100) | round(1) }}%</div>
      <div class="card-label">Quality Score ⚖</div>
    </div>
    <div class="card blue">
      <div class="card-value">{{ (metrics.overall_avg_score * 100) | round(1) }}%</div>
      <div class="card-label">Avg Score</div>
    </div>
    <div class="card purple">
      <div class="card-value">{{ metrics.avg_tokens_per_second | round(1) }}</div>
      <div class="card-label">Tokens / sec</div>
    </div>
    <div class="card">
      <div class="card-value">{{ (metrics.avg_reasoning_ratio * 100) | round(0) | int }}%</div>
      <div class="card-label">Reasoning ratio</div>
    </div>
  </div>

  <!-- ── Latency ────────────────────────────────────────────────── -->
  <section>
    <h2>Latency</h2>
    <div class="latency-grid">
      <div class="lat-cell">
        <div class="lat-value">{{ metrics.avg_latency_ms | round(0) | int }}</div>
        <div class="lat-label">Avg (ms)</div>
      </div>
      <div class="lat-cell">
        <div class="lat-value">{{ metrics.p50_latency_ms | round(0) | int }}</div>
        <div class="lat-label">P50 (ms)</div>
      </div>
      <div class="lat-cell">
        <div class="lat-value">{{ metrics.p95_latency_ms | round(0) | int }}</div>
        <div class="lat-label">P95 (ms)</div>
      </div>
      <div class="lat-cell">
        <div class="lat-value">{{ metrics.p99_latency_ms | round(0) | int }}</div>
        <div class="lat-label">P99 (ms)</div>
      </div>
      <div class="lat-cell">
        <div class="lat-value">{{ metrics.avg_tokens_per_second | round(1) }}</div>
        <div class="lat-label">TPS</div>
      </div>
    </div>
  </section>

  <!-- ── Process Quality ────────────────────────────────────────── -->
  <section>
    <h2>Process Quality</h2>
    <div class="pq-grid">
      <div class="pq-cell pq-ideal">
        <div class="pq-count">{{ metrics.ideal_count }}</div>
        <div class="pq-label">IDEAL</div>
      </div>
      <div class="pq-cell pq-lucky">
        <div class="pq-count">{{ metrics.lucky_count }}</div>
        <div class="pq-label">LUCKY</div>
      </div>
      <div class="pq-cell pq-error">
        <div class="pq-count">{{ metrics.error_count }}</div>
        <div class="pq-label">ERROR</div>
      </div>
      <div class="pq-cell pq-fail">
        <div class="pq-count">{{ metrics.fail_count }}</div>
        <div class="pq-label">FAIL</div>
      </div>
    </div>
    <div class="pq-legend">
      <span>✅ <strong>IDEAL</strong> — correct answer + sound reasoning</span>
      <span>🍀 <strong>LUCKY</strong> — correct answer, flawed reasoning</span>
      <span>⚠️ <strong>ERROR</strong> — sound reasoning, wrong answer</span>
      <span>❌ <strong>FAIL</strong> — wrong answer + poor reasoning</span>
    </div>
  </section>

  <!-- ── Category Breakdown ─────────────────────────────────────── -->
  {% if metrics.by_category %}
  <section>
    <h2>By Category</h2>
    <table>
      <thead>
        <tr>
          <th>Category</th>
          <th>Total</th>
          <th>Passed</th>
          <th>Failed</th>
          <th>Pass Rate</th>
          <th>Avg Score</th>
          <th>P50 Latency</th>
          <th>P95 Latency</th>
        </tr>
      </thead>
      <tbody>
        {% for cat_name, cat in metrics.by_category.items() | sort %}
        <tr>
          <td><strong>{{ cat_name }}</strong></td>
          <td>{{ cat.total }}</td>
          <td class="pass">{{ cat.passed }}</td>
          <td class="{% if cat.failed > 0 %}fail{% else %}muted{% endif %}">{{ cat.failed }}</td>
          <td class="{% if cat.pass_rate >= 0.8 %}pass{% elif cat.pass_rate >= 0.5 %}warn{% else %}fail{% endif %}">
            {{ (cat.pass_rate * 100) | round(1) }}%
          </td>
          <td>{{ (cat.avg_score * 100) | round(1) }}%</td>
          <td>{{ cat.p50_latency_ms | round(0) | int }} ms</td>
          <td>{{ cat.p95_latency_ms | round(0) | int }} ms</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  <!-- ── All Results ────────────────────────────────────────────── -->
  <section>
    <h2>All Results ({{ results | length }})</h2>
    <table>
      <thead>
        <tr>
          <th>Test ID</th>
          <th>Category</th>
          <th>Risk</th>
          <th>Score</th>
          <th>Pass</th>
          <th>Process Quality</th>
          <th>Latency</th>
          <th>Evaluator</th>
          <th>Response</th>
        </tr>
      </thead>
      <tbody>
        {% for r in results %}
        <tr class="{% if r.passed %}row-pass{% else %}row-fail{% endif %}">
          <td><code>{{ r.test_id }}</code></td>
          <td>{{ r.category | default("—") }}</td>
          <td>{{ r.risk_level | default("—") }}</td>
          <td><strong>{{ (r.score * 100) | round(1) }}%</strong></td>
          <td>
            <span class="badge {% if r.passed %}badge-pass{% else %}badge-nopass{% endif %}">
              {{ "PASS" if r.passed else "FAIL" }}
            </span>
          </td>
          <td>
            <span class="badge badge-{{ r.process_quality | default('n_a') }}">
              {{ r.process_quality | default("n/a") | upper }}
            </span>
          </td>
          <td class="muted">{{ r.client_latency_ms | round(0) | int }} ms</td>
          <td class="muted">{{ r.evaluator_name | default("—") }}</td>
          <td>
            <span class="truncate" title="{{ r.response | default('') }}">
              {{ r.response | default("") | truncate(80) }}
            </span>
          </td>
        </tr>
        {% if not r.passed and r.failure_reason %}
        <tr class="row-detail">
          <td colspan="9">
            ↳ <strong>Failure:</strong> {{ r.failure_reason }}
            {% if r.explanation %} &nbsp;|&nbsp; <strong>Detail:</strong> {{ r.explanation | truncate(160) }}{% endif %}
          </td>
        </tr>
        {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </section>

  <footer>
    Enterprise LLM QA Framework &nbsp;·&nbsp; {{ generated_at }}
    &nbsp;·&nbsp; Model: {{ metrics.model_key | default("unknown") }}
  </footer>

</div>
</body>
</html>
