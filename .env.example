# =============================================================
# LLM QA Framework — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================

# -------------------------------------------------------------
# API Connection
# -------------------------------------------------------------
BASE_URL=http://192.168.15.103:1234
TIMEOUT_SECONDS=30.0
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2.0
RETRY_MIN_WAIT_SECONDS=1.0
RETRY_MAX_WAIT_SECONDS=30.0

# -------------------------------------------------------------
# Model
# -------------------------------------------------------------
DEFAULT_MODEL_KEY=google/gemma-4-e2b

# -------------------------------------------------------------
# Execution
# -------------------------------------------------------------
# Conservative default for local LLM — avoid request queuing
MAX_PARALLEL_WORKERS=2

# -------------------------------------------------------------
# Evaluation
# -------------------------------------------------------------
DEFAULT_PASS_THRESHOLD=0.80
FUZZY_MATCH_THRESHOLD=0.85

# -------------------------------------------------------------
# Logging
# -------------------------------------------------------------
LOG_LEVEL=INFO
# Optional: write logs to file (leave blank to log to stderr only)
# LOG_FILE=logs/qa-framework.log

# -------------------------------------------------------------
# Reporting
# -------------------------------------------------------------
REPORT_DIR=reports
ENABLE_HTML_REPORT=true
ENABLE_JSON_REPORT=true
ENABLE_CSV_REPORT=true
